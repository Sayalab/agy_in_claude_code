{
  "name": "mcp-cli-core",
  "version": "1.0.0",
  "description": "Shared core library for AI CLI MCP servers — subprocess runner, security, types, and progress utilities",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "cli"
  ],
  "author": "Nadim Tuhin <nadimtuhin@gmail.com>",
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "bun build src/index.ts --target bun --outfile dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  }
}
